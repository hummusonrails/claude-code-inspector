{
  "name": "claude-dashboard-local",
  "version": "1.0.0",
  "description": "A local dashboard that visualizes your Claude Code usage, costs, and patterns",
  "license": "AGPL-3.0",
  "private": false,
  "bin": {
    "claude-dashboard-local": "bin/cli.js",
    "cci": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    ".next/standalone/",
    ".next/static/",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pro": "mkdir -p node_modules/@hummusonrails/cci-pro && cp -r ../cci-pro/src ../cci-pro/package.json node_modules/@hummusonrails/cci-pro/ && cp src/pro-loader.pro.ts src/pro-loader.ts && next build && cp src/pro-loader.null.ts src/pro-loader.ts",
    "start": "next start",
    "lint": "eslint",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hummusonrails/claude-code-inspector.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "dashboard",
    "analytics",
    "token-usage",
    "developer-tools",
    "visualization",
    "3d"
  ],
  "author": "Ben Greenberg",
  "homepage": "https://github.com/hummusonrails/claude-code-inspector",
  "bugs": {
    "url": "https://github.com/hummusonrails/claude-code-inspector/issues"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "@types/three": "^0.183.1",
    "d3": "^7.9.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
